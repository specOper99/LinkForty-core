# =============================================================================
# LinkForty self-host (production) — copy to repo root as .env
#   cp deploy/selfhost/env.example .env
# Prefer alphanumeric for POSTGRES_PASSWORD and REDIS_PASSWORD.
# Leave ADMIN_PASSWORD unset. Never commit .env.
# Prefer: bash deploy/selfhost/bootstrap.sh (fills this interactively).
# =============================================================================

# --- Domains (HTTPS via Caddy) ---
# DNS A/AAAA for both hosts → this server
CORS_ORIGIN=https://dashboard.example.com
AUTH_URL=https://dashboard.example.com
SHORTLINK_BASE_URL=https://links.example.com
SHORTLINK_DOMAIN=links.example.com
CORE_URL=http://linkforty:3000
TRUST_PROXY=1

# --- Postgres (internal only) ---
POSTGRES_DB=linkforty
POSTGRES_USER=linkforty
POSTGRES_PASSWORD=REPLACE_WITH_openssl_rand_hex_24

# --- Redis (requirepass) ---
REDIS_PASSWORD=REPLACE_WITH_openssl_rand_hex_24

# --- Core ---
JWT_SECRET=REPLACE_WITH_openssl_rand_base64_48

# --- Dashboard auth ---
AUTH_SECRET=REPLACE_WITH_openssl_rand_base64_48
ADMIN_USERNAME=admin
# bcrypt → base64 (no $ in .env). Generated by bootstrap.sh
ADMIN_PASSWORD_HASH_B64=REPLACE_ME
OPERATOR_USER_ID=REPLACE_WITH_uuidgen
