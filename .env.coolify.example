# =============================================================================
# LinkForty Coolify (single Compose resource)
# Copy into Coolify Environment Variables, or: cp .env.coolify.example .env
# Compose file: docker-compose.coolify.yml
# Full guide: COOLIFY.md
# =============================================================================

# -----------------------------------------------------------------------------
# Postgres (internal — not published to host)
# -----------------------------------------------------------------------------
POSTGRES_DB=linkforty
POSTGRES_USER=linkforty
POSTGRES_PASSWORD=replace-with-strong-password

# -----------------------------------------------------------------------------
# Core (linkforty service)
# -----------------------------------------------------------------------------
NODE_ENV=production
# Required — do not leave empty (Compose ${JWT_SECRET:?…} will fail the deploy)
JWT_SECRET=replace-with-long-random-string

# Public dashboard origin(s) for CORS — NOT * in production
CORS_ORIGIN=https://dashboard.example.com

# Behind Coolify/Traefik
TRUST_PROXY=1

# Optional: public shortlink host used in QR / OG URLs
# SHORTLINK_DOMAIN=links.example.com

# -----------------------------------------------------------------------------
# Dashboard (Next.js BFF)
# -----------------------------------------------------------------------------
# Internal Core origin (same compose network). Do NOT use Cloudflare public host.
CORE_URL=http://linkforty:3000

# Public shortlink domain shown in UI (browser-facing)
SHORTLINK_BASE_URL=https://links.example.com

# Optional Bearer if a gateway wraps Core (vanilla Core: leave empty)
# CORE_API_TOKEN=

# Auth.js session encryption (openssl rand -base64 32)
AUTH_SECRET=replace-with-long-random-string

# Public dashboard URL — must match Coolify Domains FQDN (NO :3001)
AUTH_URL=https://dashboard.example.com
AUTH_TRUST_HOST=true

# Single-operator credentials
ADMIN_USERNAME=admin
# Prefer bcrypt:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 12))"
# Coolify / this .env: escape EVERY $ as $$ or Compose warns
#   The "zU2dGbpZ0j" variable is not set  and mangled the hash.
# Example (fake): ADMIN_PASSWORD_HASH=$$2b$$12$$zU2dGbpZ0jReplaceWithRealHash
ADMIN_PASSWORD_HASH=
# Local/dev fallback only if ADMIN_PASSWORD_HASH empty — do not use in production
# ADMIN_PASSWORD=changeme

# UUID injected as Core userId (uuidgen / crypto.randomUUID())
OPERATOR_USER_ID=00000000-0000-4000-8000-000000000001
