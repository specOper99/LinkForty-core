# =============================================================================
# LinkForty Coolify (single Compose resource)
# Copy into Coolify Environment Variables, or: cp .env.coolify.example .env
# Compose file: docker-compose.coolify.yml
# Full guide: COOLIFY.md
#
# Coolify UI: uncheck "Available at Buildtime" for NODE_ENV + all secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Postgres (internal — not published to host)
# -----------------------------------------------------------------------------
# Alphanumeric password only — compose builds DATABASE_URL from these.
# Leave DATABASE_URL unset in Coolify UI (compose sets it).
POSTGRES_DB=linkforty
POSTGRES_USER=linkforty
POSTGRES_PASSWORD=replaceWithStrongPassword

# -----------------------------------------------------------------------------
# Core (linkforty service)
# -----------------------------------------------------------------------------
NODE_ENV=production
JWT_SECRET=replace-with-long-random-string

# Public dashboard origin(s) for CORS — NOT * in production
CORS_ORIGIN=https://dashboard.example.com

# Behind reverse proxy
TRUST_PROXY=1

# Optional: public shortlink host used in QR / OG URLs
# SHORTLINK_DOMAIN=links.example.com

# -----------------------------------------------------------------------------
# Dashboard (Next.js BFF)
# -----------------------------------------------------------------------------
CORE_URL=http://linkforty:3000
SHORTLINK_BASE_URL=https://links.example.com
# CORE_API_TOKEN=

AUTH_SECRET=replace-with-long-random-string
AUTH_URL=https://dashboard.example.com
AUTH_TRUST_HOST=true

ADMIN_USERNAME=admin
# Prefer base64 bcrypt (no $) — Coolify/Compose mangle raw $2b$… hashes.
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 12))"
#   node -e "console.log(Buffer.from(process.argv[1]).toString('base64'))" '$2b$12$…'
# Example for hash $2b$12$zU2dGbpZ0j/knf5q8fiUCeXAdiCY1yCRn6/EODqgF5BLZFJY40o66:
ADMIN_PASSWORD_HASH_B64=JDJiJDEyJHpVMmRHYnBaMGova25mNXE4ZmlVQ2VYQWRpQ1kxeUNSbjYvRU9EcWdGNUJMWkZKWTQwbzY2
# Leave empty on Coolify (use B64 above):
ADMIN_PASSWORD_HASH=
# Local/dev fallback only — do not use in production
# ADMIN_PASSWORD=changeme

OPERATOR_USER_ID=00000000-0000-4000-8000-000000000001
