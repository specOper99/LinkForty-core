# LinkForty Core Dashboard — server-only env (never expose to browser)

# Existing Core origin (no trailing slash, NO /api suffix) — server-only
# Prefer PRIVATE/internal URL. Public Cloudflare hostnames often return 403 to servers.
# Wrong: https://links.example.com/api  → /api/api/...
# Wrong: https://links.example.com      → if Cloudflare Bot Fight blocks the dashboard
# Wrong: http://127.0.0.1:3000          → inside a container, that is THIS container
# Right (same Docker/Coolify network):  http://linkforty:3000
# Right (Coolify renamed alias):        http://linkforty-<core-resource-uuid>:3000
# Right (host npm run dev):             http://127.0.0.1:<published-core-port>
#
# Core health endpoints:
#   GET /api/sdk/v1/health   ← real health (use this)
#   GET /health              ← often missing; redirect catch-all returns {"error":"Link not found"}
CORE_URL=http://linkforty:3000

# Public shortlink / preview base shown in UI (optional; defaults to CORE_URL)
# SHORTLINK_BASE_URL=https://links.example.com

# Optional Bearer if your gateway/Core requires Authorization (vanilla Core: leave empty)
# CORE_API_TOKEN=

# Auth.js session encryption (openssl rand -base64 32)
AUTH_SECRET=replace-with-long-random-string

# Optional public URL of this dashboard (Auth.js / Server Actions) — required on Coolify HTTPS
# Must match the browser hostname exactly. Do NOT set this to the Core shortlink domain
# if Core also serves redirects there — use a separate host:
#   AUTH_URL=https://dashboard.example.com
#   SHORTLINK_BASE_URL=https://links.example.com
# AUTH_URL=https://dashboard.example.com

# Comma-separated extra hosts allowed for Server Actions (if AUTH_URL alone is not enough)
# SERVER_ACTIONS_ORIGINS=dashboard.example.com,localhost:3001

# Auth.js already uses trustHost=true. Behind Coolify/CF also set:
# AUTH_TRUST_HOST=true

# Listen bind (Docker/Coolify). Do not use HOSTNAME — Docker overwrites it with container id.
# HOST=0.0.0.0

# Single-operator credentials
ADMIN_USERNAME=admin
# Prefer bcrypt hash (bcrypt.hashSync('your-password', 12)):
ADMIN_PASSWORD_HASH=
# Coolify/Compose-safe alternative (base64 of the bcrypt string — no $ chars):
# ADMIN_PASSWORD_HASH_B64=
# Local-dev fallback if ADMIN_PASSWORD_HASH empty (do not use in production):
ADMIN_PASSWORD=changeme

# UUID injected as Core userId (Postgres UUID column — not "admin" / "user-1")
# Generate: uuidgen   or   node -e "console.log(crypto.randomUUID())"
OPERATOR_USER_ID=00000000-0000-4000-8000-000000000001

# Dashboard listen port (Docker / next start)
PORT=3001
NODE_ENV=development

# Shared Docker network name (must match Core compose external network)
# Create once: docker network create linkforty_shared
# COMPOSE_SHARED_NETWORK=linkforty_shared
